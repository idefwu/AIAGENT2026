# mcp_file_reader_demo.py
import json
import requests
from typing import Dict, Any
import os

# ==================== 配置 ====================
OLLAMA_BASE_URL = "http://localhost:8080/"
#API_KEY = "abc-123"  # 你設定的 key
#MODEL = "gemma4:e4b"   # 或 gemma2 等
API_KEY = "sk-1540f219fcb246b9bb55c7951491c01b" 
MODEL = "gemma4_e4b_ctx_128k_nothink:latest"

# ==================== 簡單 MCP Tool Server ====================
def read_file_tool(params: Dict) -> Dict:
    """讀取本地檔案的工具"""
    filepath = params.get("filepath")
    try:
        if not os.path.exists(filepath):
            return {"error": f"檔案不存在: {filepath}"}
        with open(filepath, "r", encoding="utf-8") as f:
            content = f.read()
        return {"content": content[:8000]}  # 避免太長
    except Exception as e:
        return {"error": str(e)}

TOOLS = [
    {
        "name": "read_file",
        "description": "讀取本地檔案內容",
        "parameters": {
            "type": "object",
            "properties": {
                "filepath": {"type": "string", "description": "檔案完整路徑"}
            },
            "required": ["filepath"]
        }
    }
]

# ==================== 呼叫 LLM ====================
def call_llm_bak(messages: list, tools=None):
    payload = {
        "model": MODEL,
        "messages": messages,
        "temperature": 0.7
    }
    if tools:
        payload["tools"] = tools

    resp = requests.post(
        f"{OLLAMA_BASE_URL}/api/chat/completions",
        json=payload,
        headers={"Authorization": f"Bearer {API_KEY}"}
    )
    return resp.json()

def call_llm(messages: list, tools=None):
    payload = {
        "model": MODEL,
        "messages": messages,
        "temperature": 0.1, # 降低隨機性，讓模型更嚴謹地遵守工具規範
    }
    if tools:
        payload["tools"] = tools
        # auto 讓模型決定，但有些 Ollama 版本需要明確給 auto 才會認真判斷
        payload["tool_choice"] = "auto" 

    resp = requests.post(
        f"{OLLAMA_BASE_URL}/api/chat/completions",
        json=payload,
        headers={"Authorization": f"Bearer {API_KEY}"}
    )
    return resp.json()


# ==================== 主流程 ====================
def main():
    print("=== MCP 檔案讀取 Agent 示範 ===")
    user_query = input("請輸入問題（例如：請幫我讀取 /tmp/test.txt 的內容）：\n")

    #messages = [
    #    {"role": "system", "content": "你是一個有工具使用的助手。需要時請使用工具。"},
    #    {"role": "user", "content": user_query}
    #]
    messages = [
        {
            "role": "system", 
            "content": (
                "你是一個具有本地檔案讀取能力的 AI 助手。\n"
                "當使用者要求你『分析』、『看』、『讀取』或提及任何檔案名稱時，"
                "你必須『先』使用 read_file 工具來獲取檔案內容，絕對不能直接回答不知道或要求使用者提供！"
            )
        },
        {"role": "user", "content": user_query}
    ]


    response = call_llm(messages, TOOLS)
    
    # 簡化處理 tool call（實際 MCP 會更完整，這裡示範概念）
    print("\n=== LLM 回應 ===")
    print(json.dumps(response, indent=2, ensure_ascii=False))

if __name__ == "__main__":
    main()