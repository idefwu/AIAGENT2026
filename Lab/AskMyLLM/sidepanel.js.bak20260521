document.getElementById('sendBtn').addEventListener('click', async () => {
  const userInput = document.getElementById('userInput').value;
  if (!userInput.trim()) return;

  const settings = await chrome.storage.local.get(['apiUrl', 'apiKey', 'model', 'sysPrompt', 'usrPrompt']);
  if (!settings.apiUrl || !settings.apiKey || !settings.model) {
    alert("請先填寫並儲存 API 設定！");
    return;
  }

  const tabs = await chrome.tabs.query({ active: true, currentWindow: true });
  const tab = tabs[0];
  if (!tab || !tab.url || tab.url.startsWith('chrome') || tab.url.startsWith('about')) {
    addMessage("Error", "無法存取此頁面內容。");
    return;
  }

  addMessage("User", userInput);
  document.getElementById('userInput').value = '';

  try {
    // --- 1. 擷取網頁內容並增加檢查 ---
    const injection = await chrome.scripting.executeScript({
      target: { tabId: tab.id },
      func: () => document.body.innerText
    });

    if (!injection || !injection[0]) {
      throw new Error("無法從網頁擷取內容。");
    }
    const pageContent = injection[0].result;

    // --- 2. 呼叫 API ---
    const fullUrl = `${settings.apiUrl.replace(/\/$/, '')}/api/chat/completions`;
    const response = await fetch(fullUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${settings.apiKey}`
      },
      body: JSON.stringify({
        model: settings.model,
        messages: [
          { role: "system", content: settings.sysPrompt || "You are a helpful assistant." },
          { role: "user", content: `Context: ${pageContent.substring(0, 5000)}\n\nQuestion: ${userInput}` }
        ]
      })
    });

    const data = await response.json();
    console.log("API Response:", data); // 除錯用：在側邊欄檢查視窗看回傳了什麼

    // --- 3. 檢查 API 回傳結構 ---
    if (data.choices && data.choices[0] && data.choices[0].message) {
      const answer = data.choices[0].message.content;
      addMessage("AI", answer);
    } else if (data.error) {
      throw new Error(`API 錯誤: ${data.error.message || JSON.stringify(data.error)}`);
    } else {
      throw new Error("API 回傳格式不正確，請檢查模型名稱或 API Key。");
    }

  } catch (error) {
    console.error(error);
    addMessage("Error", "連線失敗: " + error.message);
  }
  
  document.getElementById('userInput').focus();
});


//function addMessage(role, text) {
//  const div = document.createElement('div');
//  div.style.marginBottom = "10px";
//  div.innerHTML = `<strong>${role}:</strong> <div>${text}</div>`;
//  document.getElementById('chat').appendChild(div);
//  document.getElementById('chat').scrollTop = document.getElementById('chat').scrollHeight;
//}
function addMessage(role, text) {
  const chat = document.getElementById('chat');
  const div = document.createElement('div');
  div.className = 'msg';

  const isAI = role === "AI";
  const label = isAI ? "🤖 AI Assistant" : "👤 User";
  const labelClass = isAI ? "msg-ai" : "msg-user";

  let content;
  if (isAI) {
    // 檢查 marked 是否真的載入成功
    if (typeof marked !== 'undefined') {
      // 如果 marked 是物件而非函式（某些版本差異），請用 marked.parse()
      content = (typeof marked.parse === 'function') ? marked.parse(text) : marked(text);
    } else {
      // 萬一還是沒載入，至少把換行處理好
      content = text.replace(/\n/g, '<br>');
      console.error("Marked library is still not defined!");
    }
  } else {
    content = text;
  }

  div.innerHTML = `
    <div class="${labelClass}">${label}:</div>
    <div class="${isAI ? 'msg-ai' : ''}">${content}</div>
  `;

  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}


document.getElementById('clearBtn').addEventListener('click', () => {
  if (confirm("確定要清除對話紀錄嗎？")) {
    document.getElementById('chat').innerHTML = '<div style="color: #888; font-size: 13px; text-align: center;">對話已清除</div>';
  }
});


// 監聽鍵盤事件
document.getElementById('userInput').addEventListener('keydown', (event) => {
  // 如果按下的是 Enter 鍵
  if (event.key === 'Enter') {
    // 檢查是否同時按下了 Ctrl (或 Mac 的 Meta 鍵)
    if (event.ctrlKey || event.metaKey) {
      // 1. Ctrl + Enter: 插入換行
      const start = event.target.selectionStart;
      const end = event.target.selectionEnd;
      const value = event.target.value;

      // 手動在光標位置插入換行符
      event.target.value = value.substring(0, start) + "\n" + value.substring(end);
      // 將光標移回正確的位置
      event.target.selectionStart = event.target.selectionEnd = start + 1;
      
      event.preventDefault(); // 防止預設的發送行為
    } else {
      // 2. 單獨 Enter: 執行發送邏輯
      event.preventDefault(); // 防止 textarea 預設的換行
      document.getElementById('sendBtn').click(); // 模擬點擊發送按鈕
    }
  }
});


// --- 抓重點功能邏輯 ---
document.getElementById('summarizeBtn').addEventListener('click', async () => {
  const settings = await chrome.storage.local.get(['apiUrl', 'apiKey', 'model', 'sysPrompt', 'usrPrompt']);
  
  if (!settings.apiUrl || !settings.apiKey || !settings.model) {
    alert("請先儲存 API 設定！");
    return;
  }

  // 自動定義的問題指令
  const summaryTask = "請針對這篇網頁內容抓出五個重點。如果內容不足五個重點，請以專業評論員的角色，針對現有資訊進行深度匯整與評析。請以繁體中文回覆，並且忽略網頁上除了明顯本文之外的相關訊息以免失焦，也不必自我介紹。如果真的沒有得回答，就直接說抱歉因為「提供的網頁格式目前不支援。」。";

  addMessage("User", "請幫我抓出這網頁的重點。");

  const tabs = await chrome.tabs.query({ active: true, currentWindow: true });
  const tab = tabs[0];

  if (!tab || !tab.url || tab.url.startsWith('chrome')) {
    addMessage("Error", "無法存取此頁面內容。");
    return;
  }

  try {
    const injection = await chrome.scripting.executeScript({
      target: { tabId: tab.id },
      func: () => document.body.innerText
    });

    const pageContent = injection[0].result;

    // 呼叫 API
    const response = await fetch(`${settings.apiUrl.replace(/\/$/, '')}/api/chat/completions`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${settings.apiKey}`
      },
      body: JSON.stringify({
        model: settings.model,
        messages: [
          { role: "system", content: settings.sysPrompt || "你是一位精通資訊分析的專家。" },
          { role: "user", content: `網頁內容如下：\n${pageContent.substring(0, 8000)}\n\n任務：${summaryTask}` }
        ]
      })
    });

    const data = await response.json();
    
    if (data.choices && data.choices[0]) {
      const answer = data.choices[0].message.content;
      addMessage("AI", answer);
    } else {
      throw new Error("API 回傳異常");
    }

  } catch (error) {
    addMessage("Error", "連線失敗: " + error.message);
  }
});


// --- 手動執行邏輯 ---
document.getElementById('exeBtn').addEventListener('click', async () => {
  const settings = await chrome.storage.local.get(['apiUrl', 'apiKey', 'model', 'sysPrompt', 'usrPrompt']);
  
  if (!settings.apiUrl || !settings.apiKey || !settings.model) {
    alert("請先儲存 API 設定！");
    return;
  }

  // 自動定義的問題指令
  const usrTask = settings.usrPrompt;

  addMessage("User", "請執行我自訂義的功能：" + settings.usrPrompt + "。");

  const tabs = await chrome.tabs.query({ active: true, currentWindow: true });
  const tab = tabs[0];

  if (!tab || !tab.url || tab.url.startsWith('chrome')) {
    addMessage("Error", "無法存取此頁面內容。");
    return;
  }

  try {
    const injection = await chrome.scripting.executeScript({
      target: { tabId: tab.id },
      func: () => document.body.innerText
    });

    const pageContent = injection[0].result;

    // 呼叫 API
    const response = await fetch(`${settings.apiUrl.replace(/\/$/, '')}/api/chat/completions`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${settings.apiKey}`
      },
      body: JSON.stringify({
        model: settings.model,
        messages: [
          { role: "system", content: settings.sysPrompt || "你是一位語言教學的專家。" },
          { role: "user", content: `網頁內容如下：\n${pageContent.substring(0, 8000)}\n\n任務：${usrTask}` }
        ]
      })
    });

    const data = await response.json();
    
    if (data.choices && data.choices[0]) {
      const answer = data.choices[0].message.content;
      addMessage("AI", answer);
    } else {
      throw new Error("API 回傳異常");
    }

  } catch (error) {
    addMessage("Error", "連線失敗: " + error.message);
  }
});