<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <!-- 1. 引入 Marked.js 用於處理 Markdown 格式 -->
  <!-- <script src="https://jsdelivr.net"></script> -->
  <script src="marked.min.js"></script>
  <style>
    body { 
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
      padding: 10px; 
      display: flex; 
      flex-direction: column; 
      height: 96vh; 
      margin: 0;
      background-color: #f9f9f9;
    }
    /* 設定區域樣式 */
    .config-section { 
      font-size: 12px; 
      background: #ffffff; 
      padding: 10px; 
      border-radius: 8px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      margin-bottom: 10px; 
    }
    details summary { cursor: pointer; color: #555; font-weight: bold; margin-bottom: 5px; }
    
    input, textarea { 
      width: 100%; 
      margin-bottom: 8px; 
      padding: 6px; 
      border: 1px solid #ddd; 
      border-radius: 4px;
      box-sizing: border-box;
    }
    
    /* 聊天內容區：增加行高與字體顏色 */
    #chat { 
      flex-grow: 1; 
      overflow-y: auto; 
      background: white;
      border: 1px solid #eee; 
      border-radius: 8px;
      margin-bottom: 10px; 
      padding: 10px; 
    }
    
    .msg { margin-bottom: 16px; border-bottom: 1px solid #f9f9f9; padding-bottom: 8px; }
    .msg-user { color: #007bff; font-weight: bold; margin-bottom: 4px; }
    .msg-ai { color: #333; line-height: 1.6; }

    /* Markdown 渲染微調：解決「擠在一起」的問題 */
    .msg-ai p { margin: 8px 0; }
    .msg-ai ul, .msg-ai ol { padding-left: 20px; margin: 8px 0; }
    .msg-ai h1, .msg-ai h2, .msg-ai h3 { font-size: 1.1em; margin: 12px 0 6px 0; border-left: 3px solid #28a745; padding-left: 8px; }
    
    /* 按鈕樣式組合 */
    .btn-group { display: flex; gap: 8px; }
    button { 
      cursor: pointer; 
      background: #007bff; 
      color: white; 
      border: none; 
      padding: 8px 12px; 
      border-radius: 4px;
      transition: background 0.2s;
    }
    button:hover { background: #0056b3; }
    #saveConfig { width: 100%; background: #6c757d; }
    
    /* 清除按鈕樣式 */
    #clearBtn { background: #dc3545; flex: 0 0 auto; }
    #clearBtn:hover { background: #c82333; }
    #sendBtn { flex-grow: 1; }
  </style>
</head>
<body>

  <div class="config-section">
    <details>
      <summary>⚙️ API 設定</summary>
      <input id="apiUrl" placeholder="Open WebUI URL (例如 http://127.0.0.1:8080)" />
      <input id="apiKey" type="password" placeholder="API Key" />
      <input id="model" placeholder="模型名稱 (例如 gemma20260508v1.1@jeddy)" />
      <textarea id="sysPrompt" rows="2" placeholder="系統提示詞 (System Prompt)"></textarea>
      <textarea id="usrPrompt" rows="2" placeholder="自訂義提示詞 (User Prompt)"></textarea>
      <button id="saveConfig">儲存設定</button>
    </details>
  </div>

  <div id="chat">
    <div style="color: #888; font-size: 13px; text-align: center;">請輸入問題來分析當前網頁</div>
  </div>

  <textarea id="userInput" rows="3" placeholder="對此網頁提問..."></textarea>
  
  <!-- 加入按鈕組合 -->
  <div class="btn-group">
    <button id="sendBtn">發送問題</button>
	<button id="exeBtn" style="background: #FF6D00;">私任務</button>
	<button id="summarizeBtn" style="background: #28a745;">抓重點</button>
    <button id="clearBtn">清除</button>
  </div>

  <script src="sidepanel.js"></script>
</body>
</html>
